# Vite (frontend) — copy to .env
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Firebase (Google sign-in via Firebase → Supabase session)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Razorpay: NEVER put the key secret in Vite env (it would ship to the browser).
# Local Edge Functions: create supabase/.env with:
#   RAZORPAY_KEY_ID=rzp_...
#   RAZORPAY_KEY_SECRET=...
# Hosted (production): Supabase Dashboard → Project Settings → Edge Functions → Secrets
